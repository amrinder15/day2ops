---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', p => !p.data.draft);
const sorted = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const recentPosts = sorted.slice(0, 6);

// Collect all tags
const allTags = [...new Set(sorted.flatMap(p => p.data.tags))].slice(0, 12);
---

<BaseLayout
  title="Day2Ops"
  description="Engineering insights for teams running platforms in production. Kubernetes, GitOps, SRE, observability — the hard stuff nobody writes about."
>

  <!-- Hero Section -->
  <section class="hero" data-home-hero>
    <div class="container">
      <div class="hero__inner">
        <div class="hero__content">
          <div class="hero__eyebrow" data-hero-badges>
            <span class="hero__badge liquid-chip active">Platform Engineering</span>
            <span class="hero__badge liquid-chip liquid-chip--muted">SRE</span>
            <span class="hero__badge liquid-chip liquid-chip--muted">GitOps</span>
          </div>
          <h1 class="hero__title" data-hero-title>
            What happens <em>after</em><br/>the cluster is up.
          </h1>
          <p class="hero__lead" data-hero-lead>
            Practical lessons from Day 2 operations. Kubernetes internals, GitOps at scale, observability that actually helps, and the unglamorous work of keeping platforms alive.
          </p>
          <div class="hero__actions" data-hero-actions>
            <a href="/blog" class="btn btn-primary">
              Read the blog
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>

        <!-- Animated terminal -->
        <div class="hero__terminal liquid-surface" data-hero-terminal aria-hidden="true">
          <div class="terminal">
            <div class="terminal__bar">
              <span class="terminal__dot terminal__dot--red"></span>
              <span class="terminal__dot terminal__dot--yellow"></span>
              <span class="terminal__dot terminal__dot--green"></span>
              <span class="terminal__title">day2ops ~ production</span>
            </div>
            <div class="terminal__body">
              <div class="terminal__line"><span class="terminal__prompt">$</span> kubectl get pods -A | grep -v Running</div>
              <div class="terminal__line terminal__line--output terminal__line--fade1">NAMESPACE   NAME                     STATUS</div>
              <div class="terminal__line terminal__line--output terminal__line--fade2 terminal__line--warn">payments    invoice-svc-7d9b4   <span class="terminal__status--warn">OOMKilled</span></div>
              <div class="terminal__line terminal__line--output terminal__line--fade3 terminal__line--warn">monitoring  alertmanager-0          <span class="terminal__status--warn">Pending</span></div>
              <div class="terminal__line terminal__line--fade4"><span class="terminal__prompt">$</span> <span class="terminal__cursor"></span></div>
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- Decorative grid lines -->
    <div class="hero__grid" data-hero-grid aria-hidden="true"></div>
  </section>

  <!-- Stats bar -->
  <div class="stats-bar" data-home-stats>
    <div class="container">
      <div class="stats-bar__inner">
        <div class="stat">
          <span class="stat__num">{sorted.length}</span>
          <span class="stat__label">Posts Published</span>
        </div>
        <div class="stat__divider" aria-hidden="true"></div>
        <div class="stat">
          <span class="stat__num">{allTags.length}+</span>
          <span class="stat__label">Topics Covered</span>
        </div>
        <div class="stat__divider" aria-hidden="true"></div>
        <div class="stat">
          <span class="stat__num">0</span>
          <span class="stat__label">Fluff Articles</span>
        </div>
        <div class="stat__divider" aria-hidden="true"></div>
        <div class="stat">
          <span class="stat__num">∞</span>
          <span class="stat__label">3AM Incidents Referenced</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Recent posts grid -->
  {recentPosts.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-title reveal">
          <h2>Recent Posts</h2>
          <div class="section-title__line"></div>
          <a href="/blog" class="btn btn-ghost" style="flex-shrink:0;">View all</a>
        </div>
        <div class="recent-carousel reveal reveal-delay-1 liquid-surface" data-home-recent data-recent-carousel>
          <div class="recent-carousel__header">
            <div class="recent-carousel__controls" aria-label="Recent post carousel controls">
              <button class="recent-carousel__control" type="button" data-carousel-direction aria-label="Reverse scroll direction">
                <span aria-hidden="true">⇄</span>
              </button>
            </div>
          </div>

          <div class="recent-carousel__viewport">
            <div class="recent-carousel__track" data-carousel-track>
              <div class="recent-carousel__group" data-carousel-group>
                {recentPosts.map((post, i) => (
                  <div class="recent-carousel__slide" data-carousel-slide>
                    <PostCard post={post} index={i} />
                  </div>
                ))}
              </div>
              {recentPosts.length > 1 && (
                <div class="recent-carousel__group recent-carousel__group--clone" aria-hidden="true" inert>
                  {recentPosts.map((post, i) => (
                    <div class="recent-carousel__slide recent-carousel__slide--clone">
                      <PostCard post={post} index={i} />
                    </div>
                  ))}
                </div>
              )}
            </div>
          </div>

          <p class="sr-only" aria-live="polite" data-carousel-status>
            Auto-scrolling through {recentPosts.length} recent posts.
          </p>
        </div>
      </div>
    </section>
  )}

  <!-- Tags cloud -->
  {allTags.length > 0 && (
    <section class="section" style="padding-top:0;">
      <div class="container">
        <div class="section-title reveal">
          <h2>Browse by Topic</h2>
          <div class="section-title__line"></div>
        </div>
        <div class="tags-cloud reveal" data-home-topics>
          {allTags.map(tag => (
            <a href={`/tags/${tag}`} class="tag tag--lg">{tag}</a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Platform engineering showcase -->
  <section class="section platform-section">
    <div class="container">
      <div class="platform-showcase reveal liquid-surface liquid-surface--interactive" data-home-platform>
        <div class="platform-showcase__copy">
          <h2 class="platform-showcase__title">Create delivery systems teams trust when production gets noisy.</h2>
          <p class="platform-showcase__body">Day 2 work is paved roads, feedback loops, and guardrails that keep velocity high without turning every release into a gamble.</p>
          <div class="platform-showcase__tags" aria-label="Platform engineering themes">
            <span class="tag">Golden Paths</span>
            <span class="tag">GitOps Control</span>
            <span class="tag">Runtime Signals</span>
          </div>
          <div class="platform-showcase__actions">
            <a href="/blog" class="btn btn-primary">Explore platform stories</a>
            <a href="/tags" class="btn btn-ghost">Browse all topics</a>
          </div>
        </div>

        <div class="platform-showcase__board" aria-hidden="true">
          <div class="platform-showcase__orb"></div>
          <div class="platform-lane">
            <div class="platform-lane__header">
              <span class="platform-lane__label font-mono">Delivery</span>
              <strong class="platform-lane__metric">Lead time compresses</strong>
            </div>
            <div class="platform-lane__track">
              <span class="platform-lane__signal"></span>
            </div>
            <p class="platform-lane__copy">Templates, guardrails, and self-service paths reduce ticket-driven release work.</p>
          </div>

          <div class="platform-lane">
            <div class="platform-lane__header">
              <span class="platform-lane__label font-mono">Reliability</span>
              <strong class="platform-lane__metric">Incidents get shorter</strong>
            </div>
            <div class="platform-lane__track">
              <span class="platform-lane__signal"></span>
            </div>
            <p class="platform-lane__copy">Operational visibility moves from dashboards people ignore to signals teams can act on.</p>
          </div>

          <div class="platform-lane">
            <div class="platform-lane__header">
              <span class="platform-lane__label font-mono">Governance</span>
              <strong class="platform-lane__metric">Risk stays bounded</strong>
            </div>
            <div class="platform-lane__track">
              <span class="platform-lane__signal"></span>
            </div>
            <p class="platform-lane__copy">Policy, tenancy, and platform standards become part of the flow instead of afterthought audits.</p>
          </div>

          <div class="platform-showcase__metrics">
            <div class="platform-metric">
              <span class="platform-metric__value"><span data-platform-counter data-platform-target="3">0</span><span class="platform-metric__suffix"> pillars</span></span>
              <span class="platform-metric__label">Delivery, reliability, and governance designed as one system</span>
            </div>
            <div class="platform-metric">
              <span class="platform-metric__value"><span data-platform-counter data-platform-target="24">0</span><span class="platform-metric__suffix">/7 visibility</span></span>
              <span class="platform-metric__label">Operational feedback stays visible long after the release window closes</span>
            </div>
            <div class="platform-metric">
              <span class="platform-metric__value"><span data-platform-counter data-platform-target="1">0</span><span class="platform-metric__suffix"> operating model</span></span>
              <span class="platform-metric__label">Shared standards that keep product teams moving without ticket queues</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  import { initRecentCarousels } from '../lib/animations/recent-carousels';

  initRecentCarousels();
</script>

<style>
/* ── Hero ────────────────────────────────────────────────── */
.hero {
  position: relative;
  overflow: hidden;
  padding: var(--space-20) 0 var(--space-12);
  border-bottom: 1px solid var(--border);
}

.hero__grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(var(--border) 1px, transparent 1px),
    linear-gradient(90deg, var(--border) 1px, transparent 1px);
  background-size: 48px 48px;
  opacity: 0.4;
  pointer-events: none;
  mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, black 30%, transparent 100%);
  -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, black 30%, transparent 100%);
}

.hero__inner {
  display: grid;
  grid-template-columns: 1fr 480px;
  gap: var(--space-16);
  align-items: center;
  position: relative;
  z-index: 1;
}

.hero__eyebrow {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
  margin-bottom: var(--space-5);
}

.hero__badge {
  display: inline-flex;
  align-items: center;
  gap: var(--space-1);
}

.hero__title {
  font-size: clamp(2.5rem, 5vw, 4rem);
  line-height: 1.1;
  letter-spacing: -0.04em;
  margin-bottom: var(--space-5);
}

.hero__title em {
  font-style: italic;
  color: var(--accent);
}

.hero__lead {
  font-size: clamp(var(--text-base), 1.5vw, var(--text-lg));
  color: var(--fg-muted);
  max-width: 52ch;
  line-height: 1.7;
  margin-bottom: var(--space-8);
  font-weight: 300;
}

.hero__actions {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  flex-wrap: wrap;
}

/* ── Terminal Widget ─────────────────────────────────────── */
.terminal {
  background: #0d1117;
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: 0 24px 64px rgba(0,0,0,.4), 0 0 0 1px rgba(255,255,255,.04);
  font-family: 'IBM Plex Mono', monospace;
}

.terminal__bar {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-3) var(--space-4);
  background: rgba(255,255,255,.04);
  border-bottom: 1px solid rgba(255,255,255,.06);
}

.terminal__dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
}
.terminal__dot--red    { background: #ff5f57; }
.terminal__dot--yellow { background: #ffbd2e; }
.terminal__dot--green  { background: #28ca42; }

.terminal__title {
  flex: 1;
  text-align: center;
  font-size: var(--text-xs);
  color: rgba(255,255,255,.3);
  letter-spacing: 0.05em;
}

.terminal__body {
  padding: var(--space-5) var(--space-5);
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.terminal__line {
  font-size: var(--text-sm);
  color: rgba(255,255,255,.85);
  line-height: 1.5;
  opacity: 1;
}
.terminal__line--output { color: rgba(255,255,255,.55); }
.terminal__line--warn { color: rgba(255,255,255,.85); }

.terminal__prompt {
  color: #4ade80;
  margin-right: var(--space-2);
  user-select: none;
}

.terminal__status--warn { color: #fbbf24; }

.terminal__cursor {
  display: inline-block;
  width: 8px;
  height: 1.1em;
  background: rgba(255,255,255,.7);
  vertical-align: text-bottom;
  animation: blink 1.1s steps(1) infinite;
}
@keyframes blink { 50% { opacity: 0; } }

/* ── Stats bar ───────────────────────────────────────────── */
.stats-bar {
  padding: var(--space-8) 0;
  border-bottom: 1px solid var(--border);
  background: var(--bg-subtle);
}

.stats-bar__inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-8);
  flex-wrap: wrap;
}

.stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-1);
}

.stat__num {
  font-family: 'DM Serif Display', serif;
  font-size: var(--text-3xl);
  color: var(--accent);
  line-height: 1;
}

.stat__label {
  font-family: 'IBM Plex Mono', monospace;
  font-size: var(--text-xs);
  color: var(--fg-subtle);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  text-align: center;
}

.stat__divider {
  width: 1px;
  height: 48px;
  background: var(--border);
}

/* ── Recent carousel ─────────────────────────────────────── */
.recent-carousel {
  padding: var(--space-8);
  background:
    radial-gradient(circle at top, var(--accent-subtle), transparent 38%),
    linear-gradient(180deg, var(--bg-overlay), var(--bg-subtle));
  border: 1px solid var(--border);
  border-radius: calc(var(--radius-xl) + 4px);
  overflow: hidden;
  box-shadow: 0 24px 60px rgba(0,0,0,0.08);
}

.recent-carousel__header {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: var(--space-6);
  margin-bottom: var(--space-8);
}

.recent-carousel__controls {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  flex-shrink: 0;
}

.recent-carousel__control {
  min-width: 44px;
  height: 44px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999px;
  padding: 0 var(--space-4);
}

.recent-carousel__control:focus-visible {
  outline: none;
  box-shadow: var(--shadow-glow);
}

.recent-carousel__viewport {
  position: relative;
  overflow: hidden;
  padding: var(--space-4) 0;
  mask-image: linear-gradient(90deg, transparent, black 8%, black 92%, transparent);
  -webkit-mask-image: linear-gradient(90deg, transparent, black 8%, black 92%, transparent);
}

.recent-carousel__viewport::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at center, rgba(224,92,42,0.12), transparent 34%);
  pointer-events: none;
  z-index: 2;
}

.recent-carousel__track {
  display: flex;
  width: max-content;
  align-items: stretch;
  gap: var(--space-6);
}

.recent-carousel__group {
  display: flex;
  align-items: stretch;
  gap: var(--space-6);
}

.recent-carousel__group--clone {
  pointer-events: none;
}

.recent-carousel__slide {
  width: 22rem;
  flex: 0 0 22rem;
  will-change: transform, opacity;
  transition: box-shadow var(--duration-base) var(--ease-out), border-color var(--duration-base) var(--ease-out);
}

:global(.recent-carousel__slide .post-card) {
  min-height: 32rem;
  background: var(--bg-overlay);
  border: 1px solid var(--border);
  box-shadow: var(--shadow-md);
}

:global(.recent-carousel__slide .post-card__body) {
  background: linear-gradient(180deg, var(--bg-overlay), color-mix(in srgb, var(--bg-overlay) 68%, var(--bg-subtle)));
}

:global(.recent-carousel__slide .post-card__title) {
  color: var(--fg-base);
}

:global(.recent-carousel__slide .post-card__meta) {
  color: var(--fg-subtle);
}

:global(.recent-carousel__slide .post-card__description) {
  color: var(--fg-muted);
}

:global(.recent-carousel__slide .post-card__tags .tag) {
  background: var(--bg-subtle);
  border-color: var(--border);
  color: var(--fg-muted);
}

:global(.recent-carousel__slide[data-active="true"] .post-card) {
  border-color: color-mix(in srgb, var(--accent) 28%, var(--border));
  box-shadow: 0 26px 60px rgba(0,0,0,0.14), 0 0 0 1px rgba(224,92,42,0.08);
}

:global(.recent-carousel__slide .post-card:hover) {
  transform: translateY(-12px) scale(1.04);
  box-shadow: 0 34px 78px rgba(0,0,0,0.2), 0 0 0 1px rgba(224,92,42,0.12);
  border-color: color-mix(in srgb, var(--accent) 42%, var(--border));
}

/* ── Tags cloud ──────────────────────────────────────────── */
.tags-cloud {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-3);
}

.tag--lg {
  padding: var(--space-2) var(--space-5);
  font-size: var(--text-sm);
}

/* ── CTA Section ─────────────────────────────────────────── */
.platform-section {
  padding-bottom: var(--space-24);
}

.platform-showcase {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-12);
  align-items: stretch;
  padding: var(--space-12) var(--space-12);
  background: var(--bg-overlay);
  border: 1px solid var(--border);
  border-radius: var(--radius-xl);
  position: relative;
  overflow: hidden;
}

.platform-showcase::before {
  content: '';
  position: absolute;
  inset: auto -12% -22% auto;
  width: 360px;
  height: 360px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(224,92,42,.18), transparent 68%);
  pointer-events: none;
}

.platform-showcase__copy {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
  gap: var(--space-4);
  min-width: 0;
}

.platform-showcase__title {
  font-size: clamp(var(--text-2xl), 2.5vw, var(--text-3xl));
  line-height: 1.15;
  margin: 0;
}

.platform-showcase__body {
  font-size: var(--text-base);
  line-height: 1.7;
  max-width: 52ch;
  margin: 0;
}

.platform-showcase__tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-3);
  margin-top: 0;
}

.platform-showcase__actions {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-3);
  margin-top: 0;
  padding-top: var(--space-2);
}

.platform-showcase__board {
  position: relative;
  display: grid;
  gap: var(--space-5);
  padding: var(--space-7);
  border-radius: calc(var(--radius-xl) - 6px);
  background: linear-gradient(160deg, rgba(255,255,255,.08), rgba(255,255,255,.03));
  border: 1px solid rgba(255,255,255,.08);
  overflow: hidden;
}

.platform-showcase__orb {
  position: absolute;
  top: -3rem;
  right: -2rem;
  width: 10rem;
  height: 10rem;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,.24), rgba(240,112,64,.14) 48%, transparent 72%);
  filter: blur(8px);
  opacity: .9;
}

.platform-lane {
  position: relative;
  padding: var(--space-4);
  border-radius: var(--radius-lg);
  background: linear-gradient(180deg, rgba(10,14,20,.28), rgba(10,14,20,.14));
  border: 1px solid rgba(255,255,255,.08);
  transform-origin: center center;
}

.platform-lane__header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: var(--space-4);
  margin-bottom: var(--space-3);
}

.platform-lane__label {
  font-size: var(--text-xs);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(244,239,232,.72);
}

.platform-lane__metric {
  font-size: var(--text-sm);
  color: #fff;
}

.platform-lane__track {
  position: relative;
  height: 0.8rem;
  border-radius: 999px;
  overflow: hidden;
  background: linear-gradient(90deg, rgba(255,255,255,.06), rgba(255,255,255,.14));
  box-shadow: inset 0 1px 0 rgba(255,255,255,.08), inset 0 -8px 12px rgba(0,0,0,.14);
}

.platform-lane__track::before {
  content: '';
  position: absolute;
  inset: 2px;
  border-radius: inherit;
  background: repeating-linear-gradient(90deg, rgba(255,255,255,.12) 0 18px, transparent 18px 34px);
  opacity: .34;
}

.platform-lane__signal {
  position: absolute;
  inset: 0 auto 0 -18%;
  width: 36%;
  border-radius: inherit;
  background: linear-gradient(90deg, rgba(255,255,255,0), rgba(255,255,255,.34), rgba(240,112,64,.92), rgba(255,255,255,0));
  filter: blur(.2px);
}

.platform-lane__copy {
  margin-top: var(--space-3);
  font-size: var(--text-sm);
  line-height: 1.65;
}

.platform-showcase__metrics {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: var(--space-4);
}

.platform-metric {
  padding: var(--space-4);
  border-radius: var(--radius-lg);
  background: rgba(255,255,255,.06);
  border: 1px solid rgba(255,255,255,.08);
}

.platform-metric__value {
  display: block;
  font-family: 'IBM Plex Mono', monospace;
  font-size: var(--text-sm);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #fff;
  margin-bottom: var(--space-2);
}

.platform-metric__suffix {
  opacity: .78;
}

.platform-metric__label {
  display: block;
  font-size: var(--text-sm);
  line-height: 1.6;
}

:global(html[data-theme="light"]) .platform-showcase.liquid-surface {
  background: linear-gradient(145deg, rgba(255,255,255,.92), rgba(249,243,235,.94) 56%, rgba(244,232,219,.96));
  border-color: rgba(190,166,144,.22);
  box-shadow: 0 24px 56px rgba(112,76,49,.12), inset 0 1px 0 rgba(255,255,255,.92), inset 0 -20px 28px rgba(255,255,255,.42);
  color: var(--fg-base);
}

